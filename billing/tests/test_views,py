# billing/tests/test_views.py
"""
HTTP-level tests for billing views.
Stripe API calls are mocked. No live Stripe calls.

Run with:
  python manage.py test billing.tests.test_views \
      --settings=billing.tests.settings_test
"""
import json
from unittest.mock import MagicMock, patch

from django.test import Client, TestCase
from django.urls import reverse

from billing.models import Subscription, UserCoupon
from billing.tests.helpers import make_admin_sentinel, make_user


def _make_sub(user, status='active', stripe_customer_id=None, stripe_subscription_id=None,
              referral_code=None):
    sub = Subscription.objects.create(
        user=user,
        stripe_customer_id=stripe_customer_id or f'cus_{user.username}',
        stripe_subscription_id=stripe_subscription_id or f'sub_{user.username}',
        status=status,
    )
    if referral_code:
        sub.referral_code = referral_code
        sub.save()
    return sub


def _make_coupon(percent, *users):
    c = UserCoupon.objects.create(percent=str(percent))
    c.users.set(users)
    return c


# ---------------------------------------------------------------------------
# Membership/plans page
# ---------------------------------------------------------------------------

class PlansViewTests(TestCase):

    def setUp(self):
        super().setUp()
        self.client = Client()

    def test_unauthenticated_redirects_to_login(self):
        r = self.client.get(reverse('billing:membership'))
        self.assertRedirects(r, f'/accounts/login/?next=/billing/membership/',
                             fetch_redirect_response=False)

    def test_authenticated_no_sub_renders_200(self):
        user = make_user('pv_nosub')
        self.client.force_login(user)
        r = self.client.get(reverse('billing:membership'))
        self.assertEqual(r.status_code, 200)

    def test_pro_user_sees_discount_in_context(self):
        admin = make_admin_sentinel()
        user = make_user('pv_pro')
        sub = _make_sub(user, status='active')
        _make_coupon('20.00', user, admin)
        self.client.force_login(user)
        r = self.client.get(reverse('billing:membership'))
        self.assertEqual(r.status_code, 200)
        self.assertEqual(r.context['discount'], 20)

    def test_non_pro_discount_not_computed(self):
        user = make_user('pv_nonpro')
        _make_sub(user, status='cancelled')
        self.client.force_login(user)
        r = self.client.get(reverse('billing:membership'))
        self.assertEqual(r.status_code, 200)
        self.assertEqual(r.context['discount'], 0)

    def test_show_referral_true_for_pro_with_code(self):
        user = make_user('pv_ref1')
        _make_sub(user, status='active', referral_code='NVD-TEST1')
        self.client.force_login(user)
        r = self.client.get(reverse('billing:membership'))
        self.assertTrue(r.context['show_referral'])
        self.assertEqual(r.context['referral_code'], 'NVD-TEST1')

    def test_show_referral_true_for_pro_without_code_yet(self):
        user = make_user('pv_ref2')
        _make_sub(user, status='active')
        self.client.force_login(user)
        r = self.client.get(reverse('billing:membership'))
        self.assertTrue(r.context['show_referral'])

    def test_show_referral_false_for_cancelled_without_code(self):
        user = make_user('pv_noref')
        _make_sub(user, status='cancelled')
        self.client.force_login(user)
        r = self.client.get(reverse('billing:membership'))
        self.assertFalse(r.context['show_referral'])

    def test_active_partners_count_in_context(self):
        admin = make_admin_sentinel()
        user = make_user('pv_partners')
        partner = make_user('pv_part2')
        _make_sub(user, status='active')
        _make_sub(partner, status='active')
        _make_coupon('12.50', user, partner)
        self.client.force_login(user)
        r = self.client.get(reverse('billing:membership'))
        self.assertEqual(r.context['active_partners'], 1)

    def test_cancelled_partner_not_counted(self):
        user = make_user('pv_nopart')
        partner = make_user('pv_nopart2')
        _make_sub(user, status='active')
        _make_sub(partner, status='cancelled')
        _make_coupon('12.50', user, partner)
        self.client.force_login(user)
        r = self.client.get(reverse('billing:membership'))
        self.assertEqual(r.context['active_partners'], 0)


# ---------------------------------------------------------------------------
# generate_referral_code endpoint
# ---------------------------------------------------------------------------

class GenerateReferralCodeViewTests(TestCase):

    def setUp(self):
        super().setUp()
        self.client = Client()
        self.url = reverse('billing:generate_referral_code')

    def test_get_rejected_405(self):
        user = make_user('grv_get')
        _make_sub(user, status='active')
        self.client.force_login(user)
        r = self.client.get(self.url)
        self.assertEqual(r.status_code, 405)

    def test_unauthenticated_redirects(self):
        r = self.client.post(self.url)
        self.assertEqual(r.status_code, 302)

    def test_non_pro_gets_403(self):
        user = make_user('grv_nonpro')
        _make_sub(user, status='cancelled')
        self.client.force_login(user)
        r = self.client.post(self.url)
        self.assertEqual(r.status_code, 403)
        data = json.loads(r.content)
        self.assertIn('error', data)

    def test_no_subscription_gets_403(self):
        user = make_user('grv_nosub')
        self.client.force_login(user)
        r = self.client.post(self.url)
        self.assertEqual(r.status_code, 403)

    def test_existing_code_returned_without_stripe_call(self):
        user = make_user('grv_exist')
        _make_sub(user, status='active', referral_code='NVD-EXIST')
        self.client.force_login(user)
        with patch('billing.models.stripe') as mock_stripe:
            r = self.client.post(self.url)
            mock_stripe.PromotionCode.create.assert_not_called()
        self.assertEqual(r.status_code, 200)
        data = json.loads(r.content)
        self.assertEqual(data['code'], 'NVD-EXIST')

    def test_pro_user_generates_new_code(self):
        user = make_user('grv_new')
        _make_sub(user, status='active')
        self.client.force_login(user)
        with patch('billing.models.stripe') as mock_stripe:
            mock_stripe.Coupon.delete.side_effect = Exception('not found')
            mock_stripe.Coupon.create.return_value = MagicMock(id=f'nvd-referral-{user.pk}')
            mock_stripe.PromotionCode.create.return_value = MagicMock(id='promo_new')
            r = self.client.post(self.url)
        self.assertEqual(r.status_code, 200)
        data = json.loads(r.content)
        self.assertIn('code', data)
        self.assertTrue(data['code'].startswith('NVD-'))

    def test_stripe_error_returns_500(self):
        user = make_user('grv_err')
        _make_sub(user, status='active')
        self.client.force_login(user)
        with patch('billing.models.stripe') as mock_stripe:
            mock_stripe.Coupon.delete.return_value = None
            mock_stripe.Coupon.create.side_effect = Exception('stripe down')
            r = self.client.post(self.url)
        self.assertEqual(r.status_code, 500)
        data = json.loads(r.content)
        self.assertIn('error', data)

    def test_trialing_user_can_generate_code(self):
        # trialing is is_pro=True
        user = make_user('grv_trial')
        _make_sub(user, status='trialing')
        self.client.force_login(user)
        with patch('billing.models.stripe') as mock_stripe:
            mock_stripe.Coupon.delete.return_value = None
            mock_stripe.Coupon.create.return_value = MagicMock()
            mock_stripe.PromotionCode.create.return_value = MagicMock(id='promo_trial')
            r = self.client.post(self.url)
        self.assertEqual(r.status_code, 200)


