# Checkout view
# ---------------------------------------------------------------------------

class CheckoutViewTests(TestCase):

    def setUp(self):
        super().setUp()
        self.client = Client()
        self.url = reverse('billing:checkout')

    def test_unauthenticated_redirects(self):
        r = self.client.get(self.url)
        self.assertEqual(r.status_code, 302)

    def test_creates_checkout_session_and_redirects(self):
        user = make_user('co_ok')
        mock_session = MagicMock()
        mock_session.url = 'https://checkout.stripe.com/pay/test_xxx'
        with patch('billing.views.pages.stripe') as mock_stripe:
            mock_stripe.Customer.create.return_value = MagicMock(id='cus_co_ok')
            mock_stripe.checkout.Session.create.return_value = mock_session
            self.client.force_login(user)
            r = self.client.get(self.url)
        self.assertRedirects(r, 'https://checkout.stripe.com/pay/test_xxx',
                             fetch_redirect_response=False)

    def test_checkout_uses_allow_promotion_codes(self):
        """Promotion codes must be accepted on Stripe's hosted page."""
        user = make_user('co_promo')
        mock_session = MagicMock()
        mock_session.url = 'https://checkout.stripe.com/pay/test_yyy'
        with patch('billing.views.pages.stripe') as mock_stripe:
            mock_stripe.Customer.create.return_value = MagicMock(id='cus_co_promo')
            mock_stripe.checkout.Session.create.return_value = mock_session
            self.client.force_login(user)
            self.client.get(self.url)
        _, kwargs = mock_stripe.checkout.Session.create.call_args
        self.assertTrue(kwargs.get('allow_promotion_codes'))

    def test_existing_customer_reuses_subscription_record(self):
        user = make_user('co_exist')
        _make_sub(user, status='cancelled', stripe_customer_id='cus_co_exist')
        mock_session = MagicMock()
        mock_session.url = 'https://checkout.stripe.com/pay/test_zzz'
        with patch('billing.views.pages.stripe') as mock_stripe:
            mock_stripe.checkout.Session.create.return_value = mock_session
            self.client.force_login(user)
            r = self.client.get(self.url)
        # Should not create a new customer
        mock_stripe.Customer.create.assert_not_called()
        self.assertRedirects(r, 'https://checkout.stripe.com/pay/test_zzz',
                             fetch_redirect_response=False)