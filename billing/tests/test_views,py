# Portal view
# ---------------------------------------------------------------------------

class PortalViewTests(TestCase):

    def setUp(self):
        super().setUp()
        self.client = Client()
        self.url = reverse('billing:portal')

    def test_unauthenticated_redirects(self):
        r = self.client.get(self.url)
        self.assertEqual(r.status_code, 302)

    def test_no_subscription_redirects_to_membership(self):
        user = make_user('prt_nosub')
        self.client.force_login(user)
        r = self.client.get(self.url)
        self.assertRedirects(r, reverse('billing:membership'), fetch_redirect_response=False)

    def test_no_stripe_subscription_id_redirects_with_message(self):
        user = make_user('prt_noid')
        _make_sub(user, status='active', stripe_subscription_id=None,
                  stripe_customer_id='cus_prt_noid')
        # Force stripe_subscription_id to None
        sub = user.subscription
        sub.stripe_subscription_id = None
        sub.save()
        self.client.force_login(user)
        r = self.client.get(self.url)
        self.assertRedirects(r, reverse('billing:membership'), fetch_redirect_response=False)

    def test_valid_subscription_redirects_to_stripe_portal(self):
        user = make_user('prt_ok')
        _make_sub(user, status='active',
                  stripe_customer_id='cus_prt_ok',
                  stripe_subscription_id='sub_prt_ok')
        self.client.force_login(user)
        mock_session = MagicMock()
        mock_session.url = 'https://billing.stripe.com/session/test_xxx'
        with patch('billing.views.pages.stripe') as mock_stripe:
            mock_stripe.billing_portal.Session.create.return_value = mock_session
            r = self.client.get(self.url)
        self.assertRedirects(r, 'https://billing.stripe.com/session/test_xxx',
                             fetch_redirect_response=False)

    def test_stripe_error_redirects_to_membership_with_message(self):
        user = make_user('prt_err')
        _make_sub(user, status='active',
                  stripe_customer_id='cus_prt_err',
                  stripe_subscription_id='sub_prt_err')
        self.client.force_login(user)
        with patch('billing.views.pages.stripe') as mock_stripe:
            mock_stripe.billing_portal.Session.create.side_effect = \
                Exception('stripe error')
            mock_stripe.error.StripeError = Exception
            r = self.client.get(self.url)
        self.assertRedirects(r, reverse('billing:membership'), fetch_redirect_response=False)


